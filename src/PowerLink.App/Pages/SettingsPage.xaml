<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="PageRoot"
    x:Class="PowerLink.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PowerLink.App.ViewModels"
    Background="Transparent">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Settings" Style="{ThemeResource TitleTextBlockStyle}"/>

            <Border Grid.Row="1" CornerRadius="8" Padding="20" BorderThickness="1"
                    BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                    Background="{ThemeResource SubtleFillColorTransparentBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Explorer context menu"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.75"
                               Text="Choose which PowerLink entries to add to the right-click menu. Every verb here works with NTFS hardlinks (one file, multiple names — not copies, not symlinks). Per-user registry, no admin. On Windows 11 these appear under 'Show more options'."/>

                    <ToggleSwitch IsOn="{x:Bind ViewModel.GroupedLayout, Mode=TwoWay}"
                                  Header="Group under a single 'PowerLink' submenu"
                                  OffContent="Flat — each verb is its own top-level entry"
                                  OnContent="Grouped — one 'PowerLink' item that cascades into the selected verbs"/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Verbs, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShellVerbViewModel">
                                <Border Margin="0,0,0,6" Padding="12" CornerRadius="6" BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{x:Bind ShouldInstall, Mode=TwoWay}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind Description}" Opacity="0.7" TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind TargetsText}" Opacity="0.5"
                                                       FontSize="11" FontFamily="Consolas"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind StatusText, Mode=OneWay}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource SystemAccentColor}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{x:Bind ViewModel.ApplyChangesCommand}"
                                Style="{ThemeResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Accept"/>
                                <TextBlock Text="Apply changes"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.UninstallAllCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Delete"/>
                                <TextBlock Text="Uninstall all"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.RestartExplorerCommand}"
                                ToolTipService.ToolTip="Restart explorer.exe so menu changes take effect">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Refresh"/>
                                <TextBlock Text="Restart Explorer"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.OperationStatus, Mode=OneWay}"
                               Opacity="0.8" TextWrapping="Wrap"/>

                    <StackPanel Spacing="2" Margin="0,4,0,0">
                        <TextBlock Text="CLI path:" FontWeight="SemiBold" Opacity="0.7"/>
                        <TextBlock Text="{x:Bind ViewModel.CliPath, Mode=OneWay}"
                                   FontFamily="Consolas" Opacity="0.7"
                                   TextWrapping="Wrap" FontSize="11"/>
                        <TextBlock Text="App path:" FontWeight="SemiBold" Opacity="0.7" Margin="0,4,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.AppPath, Mode=OneWay}"
                                   FontFamily="Consolas" Opacity="0.7"
                                   TextWrapping="Wrap" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" CornerRadius="8" Padding="20" BorderThickness="1"
                    BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                    Background="{ThemeResource SubtleFillColorTransparentBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Windows 11 modern menu (experimental)"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.75"
                               Text="Adds a 'PowerLink' submenu to the TOP section of the Win11 right-click menu (no 'Show more options' needed). Registers a sparse MSIX package pointing at this app's folder — no signing. Requires Windows Developer Mode (Settings → Privacy &amp; security → For developers)."/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.ModernVerbs, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShellVerbViewModel">
                                <Border Margin="0,0,0,6" Padding="12" CornerRadius="6" BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{x:Bind ShouldInstall, Mode=TwoWay}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind Description}" Opacity="0.7" TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind TargetsText}" Opacity="0.5"
                                                       FontSize="11" FontFamily="Consolas"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind StatusText, Mode=OneWay}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource SystemAccentColor}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{x:Bind ViewModel.ApplyModernChangesCommand}"
                                Style="{ThemeResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Registers/unregisters the AppX layout package via PackageManager. Windows Developer Mode must be on.">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Accept"/>
                                <TextBlock Text="Apply changes"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.RestartExplorerCommand}"
                                ToolTipService.ToolTip="Restart explorer.exe so the new menu entry appears">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Refresh"/>
                                <TextBlock Text="Restart Explorer"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.ModernStatus, Mode=OneWay}"
                               Opacity="0.8" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" CornerRadius="8" Padding="20" BorderThickness="1"
                    BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                    Background="{ThemeResource SubtleFillColorTransparentBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Overlay icons"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.75"
                               Text="Small badge on file icons in Explorer for files that are hardlinks (have 2+ names on disk). Requires admin to install — Windows reads overlay handlers only from HKLM, not per-user. Uses 1 of 15 system-wide overlay slots."/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.OverlayVerbs, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShellVerbViewModel">
                                <Border Margin="0,0,0,6" Padding="12" CornerRadius="6" BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{x:Bind ShouldInstall, Mode=TwoWay}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind Description}" Opacity="0.7" TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind TargetsText}" Opacity="0.5"
                                                       FontSize="11" FontFamily="Consolas"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind StatusText, Mode=OneWay}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource SystemAccentColor}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{x:Bind ViewModel.ApplyOverlayChangesCommand}"
                                Style="{ThemeResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Triggers UAC — overlay handlers register in HKLM">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Permissions"/>
                                <TextBlock Text="Apply (requires admin)"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.RestartExplorerCommand}"
                                ToolTipService.ToolTip="Restart explorer.exe so the badge appears or disappears">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Refresh"/>
                                <TextBlock Text="Restart Explorer"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.ClearIconCacheCommand}"
                                ToolTipService.ToolTip="Wipe Explorer's icon cache (iconcache_*.db) and restart explorer.exe. Use after rebuilding the overlay DLL — Windows otherwise keeps showing old badges. First folder open will be slower as the cache rebuilds.">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Delete"/>
                                <TextBlock Text="Clear icon cache"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.OverlayStatus, Mode=OneWay}"
                               Opacity="0.8" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" CornerRadius="8" Padding="20" BorderThickness="1"
                    BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                    Background="{ThemeResource SubtleFillColorTransparentBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Drag-and-drop actions"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.75"
                               Text="Right-drag files or folders onto a folder and pick a PowerLink action from the menu. One DLL exposes 'Hardlink here' (for files) and 'Clone tree here' (for folders). Per-user HKCU — no admin."/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.DropVerbs, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShellVerbViewModel">
                                <Border Margin="0,0,0,6" Padding="12" CornerRadius="6" BorderThickness="1"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{x:Bind ShouldInstall, Mode=TwoWay}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind Description}" Opacity="0.7" TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind TargetsText}" Opacity="0.5"
                                                       FontSize="11" FontFamily="Consolas"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind StatusText, Mode=OneWay}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource SystemAccentColor}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{x:Bind ViewModel.ApplyDropChangesCommand}"
                                Style="{ThemeResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Accept"/>
                                <TextBlock Text="Apply changes"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.RestartExplorerCommand}"
                                ToolTipService.ToolTip="Restart explorer.exe so drop-handler changes take effect">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Refresh"/>
                                <TextBlock Text="Restart Explorer"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.DropStatus, Mode=OneWay}"
                               Opacity="0.8" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" CornerRadius="8" Padding="20" BorderThickness="1"
                    BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                    Background="{ThemeResource SubtleFillColorTransparentBrush}">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Currently picked source"/>
                        <Button Grid.Column="1"
                                Command="{x:Bind ViewModel.RefreshPickedCommand}"
                                Background="Transparent" BorderBrush="Transparent"
                                ToolTipService.ToolTip="Refresh">
                            <SymbolIcon Symbol="Refresh"/>
                        </Button>
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.PickedPathText, Mode=OneWay}"
                               TextWrapping="Wrap" FontFamily="Consolas"
                               Visibility="{x:Bind ViewModel.PickedVisibility, Mode=OneWay}"/>
                    <TextBlock Text="Nothing picked yet. Right-click a file or folder in Explorer and choose 'PowerLink: Pick as link source'."
                               TextWrapping="Wrap" Opacity="0.6"
                               Visibility="{x:Bind ViewModel.NoPickVisibility, Mode=OneWay}"/>
                    <Button Command="{x:Bind ViewModel.ClearPickCommand}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Clear"/>
                            <TextBlock Text="Clear pick"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="6" Opacity="0.5" FontSize="12"
                       Text="Context menu verbs and drop handlers live under HKCU (per-user, no admin). Overlay handlers live under HKLM (admin required). After any change: restart Explorer once."/>
        </Grid>
    </ScrollViewer>
</Page>
