<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="PageRoot"
    x:Class="PowerLink.App.Pages.InspectorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PowerLink.App.ViewModels"
    xmlns:conv="using:PowerLink.App.Converters"
    Background="Transparent">

    <Page.Resources>
        <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
    </Page.Resources>

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F5"     Invoked="OnScanAccelerator"/>
        <KeyboardAccelerator Key="Escape" Invoked="OnStopAccelerator"/>
    </Page.KeyboardAccelerators>

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Hardlink inspector" Style="{ThemeResource TitleTextBlockStyle}"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Opacity="0.7"
                   Text="Scans a folder and lists every file whose data is shared with other files via NTFS hardlinks. Groups show all paths inside the scan that point at the same physical file, and whether siblings exist outside."/>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Header="Folder to inspect"
                     Text="{x:Bind ViewModel.FolderPath, Mode=TwoWay}"
                     PlaceholderText="C:\path\to\folder"/>
            <Button Grid.Column="1" VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.PickFolderCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Folder"/>
                    <TextBlock Text="Browse"/>
                </StackPanel>
            </Button>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
            <Button Command="{x:Bind ViewModel.ScanCommand}"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Find"/>
                    <TextBlock Text="Scan"/>
                </StackPanel>
            </Button>
            <Button Command="{x:Bind ViewModel.CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Cancel"/>
                    <TextBlock Text="Stop"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="4" Spacing="6">
            <ProgressBar Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}"
                         Maximum="100"/>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Bind ViewModel.CurrentFileText, Mode=OneWay}"
                           Opacity="0.6" FontFamily="Consolas" FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.FilesText, Mode=OneWay}"
                           FontFamily="Consolas" Opacity="0.7"/>
            </Grid>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"/>
            <TextBlock Text="{x:Bind ViewModel.SummaryText, Mode=OneWay}"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:HardlinkGroupViewModel">
                        <Border Padding="12" Margin="0,0,0,8" CornerRadius="6"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Header}"/>
                                    <TextBlock Opacity="0.6" Text=" &#x00B7; "/>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{x:Bind FileSize, Converter={StaticResource BytesToHuman}}"/>
                                    <TextBlock Opacity="0.6" Text=" &#x00B7; saves "/>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemAccentColor}"
                                               Text="{x:Bind SavedBytes, Converter={StaticResource BytesToHuman}}"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{x:Bind PathsInScan}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <TextBlock Opacity="0.85" Text="{x:Bind}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
