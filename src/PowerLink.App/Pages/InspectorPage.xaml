<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="PageRoot"
    x:Class="PowerLink.App.Pages.InspectorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PowerLink.App.ViewModels"
    xmlns:conv="using:PowerLink.App.Converters"
    Background="Transparent">

    <Page.Resources>
        <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
    </Page.Resources>

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F5"     Invoked="OnScanAccelerator"/>
        <KeyboardAccelerator Key="Escape" Invoked="OnStopAccelerator"/>
    </Page.KeyboardAccelerators>

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Link inspector" Style="{ThemeResource TitleTextBlockStyle}"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Opacity="0.7"
                   Text="Find hardlinks (one file with multiple names on disk) and junctions (directory pointers) inside the scanned folders. Switch tabs below the scan controls to see each."/>

        <InfoBar Grid.Row="2" IsOpen="True" IsClosable="False" Severity="Informational"
                 Title="What's a hardlink? What's a junction?"
                 Message="Hardlink = one file with multiple names on the same NTFS volume; deleting one name keeps the data until the last name is gone. Junction = a directory pointer to another local folder; deleting the junction never touches the target's contents."/>

        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="Folders to inspect" Style="{ThemeResource SubtitleTextBlockStyle}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.AddFolderCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="Add folder"/>
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.ClearFoldersCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Clear"/>
                        <TextBlock Text="Clear"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="4" CornerRadius="6" BorderThickness="1"
                BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                MaxHeight="160">
            <ListView ItemsSource="{x:Bind ViewModel.Paths, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="1"
                                    Command="{Binding ElementName=PageRoot, Path=ViewModel.RemoveFolderCommand}"
                                    CommandParameter="{x:Bind}">
                                <SymbolIcon Symbol="Delete"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="12">
            <Button Command="{x:Bind ViewModel.ScanCommand}"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Find"/>
                    <TextBlock Text="Scan"/>
                </StackPanel>
            </Button>
            <Button Command="{x:Bind ViewModel.CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Cancel"/>
                    <TextBlock Text="Stop"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="6" Spacing="6">
            <ProgressBar Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}"
                         Maximum="100"/>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Bind ViewModel.CurrentFileText, Mode=OneWay}"
                           Opacity="0.6" FontFamily="Consolas" FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.FilesText, Mode=OneWay}"
                           FontFamily="Consolas" Opacity="0.7"/>
            </Grid>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"/>
            <TextBlock Text="{x:Bind ViewModel.SummaryText, Mode=OneWay}"
                       FontWeight="SemiBold" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="7" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <Expander HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="{x:Bind ViewModel.HardlinksHeader, Mode=OneWay}"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    </Expander.Header>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:HardlinkGroupViewModel">
                                <Border Padding="12" Margin="0,0,0,8" CornerRadius="6"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Header}"/>
                                            <TextBlock Opacity="0.6" Text=" &#x00B7; "/>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{x:Bind FileSize, Converter={StaticResource BytesToHuman}}"/>
                                            <TextBlock Opacity="0.6" Text=" &#x00B7; saves "/>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{ThemeResource SystemAccentColor}"
                                                       Text="{x:Bind SavedBytes, Converter={StaticResource BytesToHuman}}"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{x:Bind PathsInScan}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <TextBlock Opacity="0.85" Text="{x:Bind}"
                                                               FontFamily="Consolas" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Spacing="2" Margin="0,6,0,0"
                                                    Visibility="{x:Bind ElsewhereListVisibility}">
                                            <TextBlock Text="elsewhere (outside scanned folders):"
                                                       Opacity="0.55" FontSize="11" FontWeight="SemiBold"/>
                                            <ItemsControl ItemsSource="{x:Bind PathsElsewhere}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <TextBlock Opacity="0.55" Text="{x:Bind}"
                                                                   FontFamily="Consolas" FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <Expander HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="{x:Bind ViewModel.JunctionsHeader, Mode=OneWay}"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    </Expander.Header>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Junctions, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:JunctionViewModel">
                                <Border Padding="12" Margin="0,0,0,8" CornerRadius="6"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock FontWeight="SemiBold"
                                                       FontFamily="Consolas" FontSize="13"
                                                       Text="{x:Bind LinkPath}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Opacity="0.7"
                                                           FontFamily="Consolas" FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Text="{x:Bind Arrow}"/>
                                                <TextBlock Opacity="0.85"
                                                           FontFamily="Consolas" FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Text="{x:Bind TargetPath}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Opacity="0.6" FontSize="11"
                                                       Text="{x:Bind StatusText}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center">
                                            <Button Command="{Binding ElementName=PageRoot, Path=ViewModel.RepairJunctionCommand}"
                                                    CommandParameter="{x:Bind}"
                                                    ToolTipService.ToolTip="Pick a new target for this junction.">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <SymbolIcon Symbol="Repair"/>
                                                    <TextBlock Text="Repair..."/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding ElementName=PageRoot, Path=ViewModel.DeleteJunctionCommand}"
                                                    CommandParameter="{x:Bind}"
                                                    ToolTipService.ToolTip="Remove this junction. The target folder is NOT deleted.">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <SymbolIcon Symbol="Delete"/>
                                                    <TextBlock Text="Delete"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
