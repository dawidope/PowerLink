<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="PageRoot"
    x:Class="PowerLink.App.Pages.JunctionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PowerLink.App.ViewModels"
    Background="Transparent">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Junction" Style="{ThemeResource TitleTextBlockStyle}"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Opacity="0.7"
                   Text="Create a directory junction — a pointer that makes one folder appear at another path. Same volume or across local volumes. No admin or Developer Mode required. Deleting the junction never touches the target's contents."/>

        <InfoBar Grid.Row="2" IsOpen="True" IsClosable="False" Severity="Informational"
                 Title="What's a junction?"
                 Message="A directory pointer — the junction folder appears at its own path but its contents come from the target. Target must be a local folder (no UNC). No admin needed to create or delete. Deleting the junction removes only the pointer, never the target's contents."/>

        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Header="Target folder (where the junction points)"
                     Text="{x:Bind ViewModel.TargetPath, Mode=TwoWay}"
                     PlaceholderText="C:\path\to\real\folder"/>
            <Button Grid.Column="1" VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.PickTargetCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Folder"/>
                    <TextBlock Text="Browse"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Header="Parent folder (where the junction is created)"
                     Text="{x:Bind ViewModel.ParentPath, Mode=TwoWay}"
                     PlaceholderText="C:\path\where\junction\appears"/>
            <Button Grid.Column="1" VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.PickParentCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Folder"/>
                    <TextBlock Text="Browse"/>
                </StackPanel>
            </Button>
        </Grid>

        <TextBox Grid.Row="5"
                 Header="Junction name (auto-derived from target — edit if you want a different name)"
                 Text="{x:Bind ViewModel.LinkName, Mode=TwoWay}"
                 PlaceholderText="my-junction"/>

        <CheckBox Grid.Row="6"
                  Content="Allow missing target (create dangling junction)"
                  IsChecked="{x:Bind ViewModel.AllowMissingTarget, Mode=TwoWay}"
                  ToolTipService.ToolTip="By default the target folder must exist. Check this to create a junction whose target does not exist yet."/>

        <StackPanel Grid.Row="7" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Command="{x:Bind ViewModel.CreateCommand}"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Link"/>
                        <TextBlock Text="Create junction"/>
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.ResetCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Clear"/>
                        <TextBlock Text="Reset"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="Wrap"/>
            <TextBlock Text="{x:Bind ViewModel.SummaryText, Mode=OneWay}"
                       FontWeight="SemiBold" TextWrapping="Wrap"
                       FontFamily="Consolas" FontSize="13"/>
        </StackPanel>
    </Grid>
</Page>
