<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="PageRoot"
    x:Class="PowerLink.App.Pages.DedupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PowerLink.App.ViewModels"
    xmlns:conv="using:PowerLink.App.Converters"
    xmlns:num="using:Windows.Globalization.NumberFormatting"
    Background="Transparent">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F5"     Invoked="OnScanAccelerator"/>
        <KeyboardAccelerator Key="Escape" Invoked="OnStopAccelerator"/>
        <KeyboardAccelerator Key="Enter"  Modifiers="Control" Invoked="OnExecuteAccelerator"/>
    </Page.KeyboardAccelerators>

    <Page.Resources>
        <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
        <conv:Log2BufferSizeConverter x:Key="Log2ToBufferSize"/>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Deduplicate" Style="{ThemeResource TitleTextBlockStyle}"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Opacity="0.7"
                   Text="Pick directories to scan. Identical files (same content) will be replaced with NTFS hardlinks, recovering disk space without losing any path."/>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="Folders to scan" Style="{ThemeResource SubtitleTextBlockStyle}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.AddFolderCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="Add folder"/>
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.ClearFoldersCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Clear"/>
                        <TextBlock Text="Clear"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" CornerRadius="6" BorderThickness="1"
                BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                MaxHeight="160">
            <ListView ItemsSource="{x:Bind ViewModel.Paths, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="1"
                                    Command="{Binding ElementName=PageRoot, Path=ViewModel.RemoveFolderCommand}"
                                    CommandParameter="{x:Bind}">
                                <SymbolIcon Symbol="Delete"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Grid Grid.Row="4" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Text="Min file size:"/>
                <NumberBox Value="{x:Bind ViewModel.MinSizeMiB, Mode=TwoWay}"
                           Minimum="0" Maximum="1048576"
                           SmallChange="1" LargeChange="10"
                           SpinButtonPlacementMode="Compact"
                           ValidationMode="InvalidInputOverwritten"
                           AcceptsExpression="False" Width="160">
                    <NumberBox.NumberFormatter>
                        <num:DecimalFormatter FractionDigits="0" IntegerDigits="1" IsGrouped="False"/>
                    </NumberBox.NumberFormatter>
                </NumberBox>
                <TextBlock VerticalAlignment="Center" Text="MiB"/>

                <TextBlock VerticalAlignment="Center" Margin="24,0,0,0" Text="Hash buffer:"/>
                <Slider Value="{x:Bind ViewModel.BufferSizeLog2, Mode=TwoWay}"
                        Minimum="6" Maximum="14"
                        StepFrequency="1" SnapsTo="StepValues"
                        TickFrequency="1" TickPlacement="Outside"
                        ThumbToolTipValueConverter="{StaticResource Log2ToBufferSize}"
                        Width="220" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.BufferSizeText, Mode=OneWay}"
                           VerticalAlignment="Center" MinWidth="64"
                           FontFamily="Consolas" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
                <Button Command="{x:Bind ViewModel.ScanCommand}"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Find"/>
                        <TextBlock Text="Scan"/>
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.CancelCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Cancel"/>
                        <TextBlock Text="Stop"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="5" Spacing="6">
            <ProgressBar Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}"
                         Maximum="100"/>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{x:Bind ViewModel.PhaseText, Mode=OneWay}" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind ViewModel.CurrentFileText, Mode=OneWay}"
                               Opacity="0.6" FontFamily="Consolas" FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                    <TextBlock Text="{x:Bind ViewModel.FilesText, Mode=OneWay}" FontFamily="Consolas"/>
                    <TextBlock Text="{x:Bind ViewModel.BytesText, Mode=OneWay}"
                               Opacity="0.7" FontFamily="Consolas" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Right" MinWidth="140">
                    <TextBlock Text="{x:Bind ViewModel.SpeedText, Mode=OneWay}"
                               FontFamily="Consolas" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock Text="{x:Bind ViewModel.EtaText, Mode=OneWay}"
                               Opacity="0.7" FontFamily="Consolas" FontSize="12"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"/>
            <TextBlock Text="{x:Bind ViewModel.SummaryText, Mode=OneWay}" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="6" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{ThemeResource SubtitleTextBlockStyle}" Text="Duplicate groups"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DuplicateGroupViewModel">
                            <Border Padding="12" Margin="0,0,0,8" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind FileCount}"/>
                                        <TextBlock FontWeight="SemiBold" Text=" files &#x00D7; "/>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{x:Bind FileSize, Converter={StaticResource BytesToHuman}}"/>
                                        <TextBlock FontWeight="SemiBold" Text=" &#x2014; saves "/>
                                        <TextBlock FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}"
                                                   Text="{x:Bind WastedBytes, Converter={StaticResource BytesToHuman}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock FontWeight="SemiBold" Text="keep:"/>
                                        <TextBlock Opacity="0.85" Text="{x:Bind CanonicalPath}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{x:Bind DuplicatePaths}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <TextBlock Opacity="0.65" Text="{x:Bind}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Command="{x:Bind ViewModel.ExecuteDedupCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Accept"/>
                    <TextBlock Text="Replace duplicates with hardlinks"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>
